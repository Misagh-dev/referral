# Copy this file to ../.streamlit/secrets.toml (one level up, in the referral folder)
# and fill in your values. That file is never committed to git or included in
# the Docker image — it is mounted read-only at runtime via docker-compose.yml.

[auth]
redirect_uri  = "http://YOUR_PUBLIC_URL/_oauth/callback"
cookie_secret = "change_me_to_a_random_string"

[auth.providers.auth0]
client_id           = "YOUR_AUTH0_CLIENT_ID"
client_secret       = "YOUR_AUTH0_CLIENT_SECRET"
server_metadata_url = "https://YOUR_AUTH0_DOMAIN/.well-known/openid-configuration"

# Comma-separated list of email addresses allowed to log in
allowed_emails = ["user@example.com"]